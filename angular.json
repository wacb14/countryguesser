{
  "$schema": "./node_modules/@angular/cli/lib/config/schema.json",
  "version": 1,
  "newProjectRoot": "projects",
  "projects": {
    "countryguesser": {
      "projectType": "application",
      "schematics": {
        "@schematics/angular:component": {
          "style": "none",
          "skipTests": true
        },
        "@schematics/angular:service": {
          "skipTests": true
        },
        "@schematics/angular:guard": {
          "skipTests": true
        },
        "@schematics/angular:directive": {
          "skipTests": true
        },
        "@schematics/angular:pipe": {
          "skipTests": true
        }
      },
      "root": "",
      "sourceRoot": "src",
      "prefix": "app",
      "architect": {
        "build": {
          "builder": "@angular/build:application",
          "options": {
            "outputPath": {
              "base": "dist/countryguesser"
            },
            "index": "src/index.html",
            "polyfills": ["zone.js"],
            "tsConfig": "tsconfig.app.json",
            "assets": ["src/favicon.ico", "src/assets"],
            "styles": [
              "src/styles.css",
              "src/assets/maps_files/dist/jqvmap.css"
            ],
            "scripts": [
              "node_modules/jquery/dist/jquery.min.js",
              "src/assets/maps_files/dist/jquery.vmap.js",
              "src/assets/maps_files/dist/maps/continents/jquery.vmap.africa.js",
              "src/assets/maps_files/dist/maps/continents/jquery.vmap.asia.js",
              "src/assets/maps_files/dist/maps/continents/jquery.vmap.australia.js",
              "src/assets/maps_files/dist/maps/continents/jquery.vmap.europe.js",
              "src/assets/maps_files/dist/maps/continents/jquery.vmap.north-america.js",
              "src/assets/maps_files/dist/maps/continents/jquery.vmap.south-america.js",
              "src/assets/maps_files/dist/maps/jquery.vmap.world.js"
            ],
            "browser": "src/main.ts"
          },
          "configurations": {
            "production": {
              "budgets": [
                {
                  "type": "initial",
                  "maximumWarning": "1.5mb",
                  "maximumError": "2mb"
                },
                {
                  "type": "anyComponentStyle",
                  "maximumWarning": "2kb",
                  "maximumError": "4kb"
                }
              ],
              "outputHashing": "all"
            },
            "development": {
              "optimization": false,
              "extractLicenses": false,
              "sourceMap": true,
              "namedChunks": true
            }
          },
          "defaultConfiguration": "production"
        },
        "serve": {
          "builder": "@angular/build:dev-server",
          "configurations": {
            "production": {
              "buildTarget": "countryguesser:build:production"
            },
            "development": {
              "buildTarget": "countryguesser:build:development"
            }
          },
          "defaultConfiguration": "development"
        },
        "extract-i18n": {
          "builder": "@angular/build:extract-i18n",
          "options": {
            "buildTarget": "countryguesser:build"
          }
        }
      }
    }
  },
  "cli": {
    "analytics": false
  },
  "schematics": {
    "@schematics/angular:component": {
      "type": "component",
      "style": "none",
      "skipTests": true
    },
    "@schematics/angular:directive": {
      "type": "directive",
      "skipTests": true
    },
    "@schematics/angular:service": {
      "type": "service",
      "skipTests": true
    },
    "@schematics/angular:guard": {
      "typeSeparator": ".",
      "skipTests": true
    },
    "@schematics/angular:interceptor": {
      "typeSeparator": "."
    },
    "@schematics/angular:module": {
      "typeSeparator": "."
    },
    "@schematics/angular:pipe": {
      "typeSeparator": ".",
      "skipTests": true
    },
    "@schematics/angular:resolver": {
      "typeSeparator": "."
    }
  }
}
